{% comment %}
  Section: Custom Homepage Featured Products
  File: sections/custom-homepage-featured-products.liquid

  Global settings (Theme Settings > Custom Homepage):
    - ch_page_width  → controls max-width of content container

  Section settings:
    - show_section   → show/hide toggle
    - text_alignment → left | center | right (applied to section header)
    - mobile_stack   → when disabled, grid columns are preserved on mobile
    - title, subtitle, columns, View All button, colors, padding
    - Blocks: "product_card" with Shopify product picker + manual overrides
{% endcomment %}

{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section -%}

{%- comment %} Mobile stack override — preserves grid columns on mobile when disabled {% endcomment %}
{%- unless section.settings.mobile_stack -%}
<style>
  @media screen and (max-width: 900px) {
    #custom-featured-products-{{ section.id }} .ch-products-grid {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr) !important;
    }
  }
  @media screen and (max-width: 640px) {
    #custom-featured-products-{{ section.id }} .ch-products-grid {
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr) !important;
    }
  }
</style>
{%- endunless -%}

<section
  id="custom-featured-products-{{ section.id }}"
  class="ch-section ch-featured-products"
  style="
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    text-align: {{ section.settings.text_alignment }};
    --ch-fp-pt: {{ section.settings.padding_top }}px;
    --ch-fp-pb: {{ section.settings.padding_bottom }}px;
    --ch-fp-cols: {{ section.settings.columns }};
    --ch-page-width: {{ settings.ch_page_width | default: 1200 }}px;
  "
>
  <div class="ch-container">

    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="ch-section-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="ch-section-header__title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="ch-section-header__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ch-products-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' -%}

            {%- liquid
              assign selected_product = block.settings.product
              assign has_product      = false
              if selected_product != blank
                assign has_product = true
              endif

              assign card_image    = block.settings.card_image
              assign card_title    = block.settings.card_title
              assign card_price    = block.settings.card_price
              assign card_btn_text = block.settings.btn_text
              assign card_btn_link = block.settings.btn_link

              if has_product
                if card_image == blank
                  assign card_image = selected_product.featured_image
                endif
                if card_title == blank
                  assign card_title = selected_product.title
                endif
                if card_price == blank
                  assign card_price = selected_product.price | money
                endif
                if card_btn_link == blank
                  assign card_btn_link = selected_product.url
                endif
              endif
            -%}

            <div class="ch-product-card" {{ block.shopify_attributes }}>

              <a
                href="{{ card_btn_link | default: '#' }}"
                class="ch-product-card__image-wrap"
                aria-label="{{ card_title | escape }}"
                tabindex="-1"
              >
                {%- if card_image != blank -%}
                  {{
                    card_image
                    | image_url: width: 800
                    | image_tag:
                      alt: card_image.alt | default: card_title,
                      loading: 'lazy',
                      widths: '300, 400, 600, 800',
                      sizes: '(max-width: 640px) 100vw, (max-width: 900px) 50vw, 33vw'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </a>

              {%- if has_product and selected_product.vendor != blank -%}
                <p class="ch-product-card__vendor">{{ selected_product.vendor }}</p>
              {%- endif -%}

              {%- if card_title != blank -%}
                <h3 class="ch-product-card__title">
                  <a href="{{ card_btn_link | default: '#' }}" style="color: inherit; text-decoration: none;">
                    {{ card_title | escape }}
                  </a>
                </h3>
              {%- endif -%}

              {%- if card_price != blank -%}
                <p class="ch-product-card__price">{{ card_price }}</p>
              {%- endif -%}

              {%- if card_btn_text != blank -%}
                <a
                  href="{{ card_btn_link | default: '#' }}"
                  class="ch-btn ch-btn--primary"
                  style="background-color: {{ section.settings.btn_color }}; border-color: {{ section.settings.btn_color }}; color: {{ section.settings.btn_text_color }};"
                >
                  {{ card_btn_text | escape }}
                </a>
              {%- endif -%}

            </div>

          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center; opacity:0.5;">Add product cards using the sidebar in the Theme Editor.</p>
    {%- endif -%}

    {%- if section.settings.view_all_text != blank -%}
      <div class="ch-section-footer">
        <a
          href="{{ section.settings.view_all_link | default: '/collections/all' }}"
          class="ch-btn ch-btn--secondary"
          style="color: {{ section.settings.text_color }}; border-color: {{ section.settings.text_color }};"
        >
          {{ section.settings.view_all_text | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Custom Featured Products",
  "tag": "section",
  "class": "ch-featured-products-section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility & Global"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "mobile_stack",
      "label": "Stack to Fewer Columns on Mobile",
      "default": true,
      "info": "When enabled, the grid collapses to 1–2 columns on small screens. Disable to keep the desktop column count."
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Title",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Handpicked just for you"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Products Per Row (Desktop)",
      "options": [
        { "value": "2", "label": "2 per row" },
        { "value": "3", "label": "3 per row" },
        { "value": "4", "label": "4 per row" }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "View All Button"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button Text",
      "default": "View All Products",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Card Button Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Card Button Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product",
          "info": "Auto-fills image, title, price, and URL. Manual fields below override these."
        },
        {
          "type": "header",
          "content": "Manual Overrides (optional)"
        },
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Card Image Override"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Product Title Override"
        },
        {
          "type": "text",
          "id": "card_price",
          "label": "Price Label Override",
          "info": "e.g. $29.99 — leave blank to use product price."
        },
        {
          "type": "header",
          "content": "Card Button"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link Override",
          "info": "Leave blank to use the selected product URL."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Featured Products",
      "settings": {
        "show_section": true,
        "text_alignment": "center",
        "mobile_stack": true,
        "heading": "Featured Products",
        "subtitle": "Handpicked just for you",
        "columns": "3",
        "view_all_text": "View All Products"
      },
      "blocks": [
        { "type": "product_card", "settings": { "btn_text": "Shop Now" } },
        { "type": "product_card", "settings": { "btn_text": "Shop Now" } },
        { "type": "product_card", "settings": { "btn_text": "Shop Now" } }
      ]
    }
  ]
}
{% endschema %}
