{% comment %}
  Section: Custom Homepage Reviews / Testimonials
  File: sections/custom-homepage-reviews.liquid

  Global settings (Theme Settings > Custom Homepage):
    - ch_page_width  → controls max-width of content container

  Section settings:
    - show_section   → show/hide toggle
    - text_alignment → left | center | right
    - title, subtitle, section/card bg colors, text color, padding
    - Blocks: "review" (star rating, text, name, avatar, product ref)
{% endcomment %}

{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section and section.blocks.size > 0 -%}

<section
  id="custom-reviews-{{ section.id }}"
  class="ch-section ch-reviews"
  style="
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    text-align: {{ section.settings.text_alignment }};
    --ch-rev-pt: {{ section.settings.padding_top }}px;
    --ch-rev-pb: {{ section.settings.padding_bottom }}px;
    --ch-page-width: {{ settings.ch_page_width | default: 1200 }}px;
  "
>
  <div class="ch-container">

    {%- if section.settings.heading != blank -%}
      <div class="ch-section-header">
        <h2 class="ch-section-header__title">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="ch-section-header__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ch-reviews-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}

          {%- liquid
            assign rating  = block.settings.rating | times: 1
            assign name    = block.settings.reviewer_name
            assign review  = block.settings.review_text
            assign avatar  = block.settings.reviewer_image
            assign product = block.settings.product_ref
          -%}

          <div
            class="ch-review-card"
            style="background-color: {{ section.settings.card_bg_color }}; text-align: left;"
            {{ block.shopify_attributes }}
          >
            <div class="ch-review-card__stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                {%- if i <= rating -%}
                  <span class="star-filled" aria-hidden="true">★</span>
                {%- else -%}
                  <span class="star-empty"  aria-hidden="true">★</span>
                {%- endif -%}
              {%- endfor -%}
            </div>

            {%- if review != blank -%}
              <p class="ch-review-card__text">"{{ review | escape }}"</p>
            {%- endif -%}

            <div class="ch-review-card__author">
              {%- if avatar != blank -%}
                {{
                  avatar
                  | image_url: width: 120
                  | image_tag:
                    alt: name | default: 'Reviewer',
                    loading: 'lazy',
                    class: 'ch-review-card__avatar',
                    widths: '42, 84',
                    sizes: '42px'
                }}
              {%- else -%}
                <div class="ch-review-card__avatar-placeholder" aria-hidden="true">
                  {{ name | slice: 0 | upcase }}
                </div>
              {%- endif -%}

              <div>
                {%- if name != blank -%}
                  <p class="ch-review-card__name">{{ name | escape }}</p>
                {%- endif -%}
                {%- if product != blank -%}
                  <p class="ch-review-card__product">{{ product | escape }}</p>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Custom Reviews",
  "tag": "section",
  "class": "ch-reviews-section",
  "settings": [
    {
      "type": "header",
      "content": "Visibility & Global"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Section Header Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Title",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Leave blank to hide."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "This product exceeded my expectations. Absolutely love it!"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Happy Customer"
        },
        {
          "type": "image_picker",
          "id": "reviewer_image",
          "label": "Reviewer Photo (optional)",
          "info": "If left blank, the reviewer's first initial is shown."
        },
        {
          "type": "text",
          "id": "product_ref",
          "label": "Product Reference (optional)",
          "info": "e.g. 'Verified purchase · Classic Tote Bag'"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Reviews",
      "settings": {
        "show_section": true,
        "text_alignment": "center",
        "heading": "What Our Customers Say"
      },
      "blocks": [
        { "type": "review", "settings": { "rating": 5, "review_text": "Absolutely love this product. Shipped fast and looks even better in person!", "reviewer_name": "Sarah M." } },
        { "type": "review", "settings": { "rating": 5, "review_text": "Excellent quality and great customer service. Will definitely order again.",  "reviewer_name": "James T." } },
        { "type": "review", "settings": { "rating": 4, "review_text": "Great value for the price. Arrived well packaged and on time.",             "reviewer_name": "Priya K." } }
      ]
    }
  ]
}
{% endschema %}
