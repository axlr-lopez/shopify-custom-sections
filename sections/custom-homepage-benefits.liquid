{% comment %}
  Section: Custom Homepage Benefits Bar
  File: sections/custom-homepage-benefits.liquid

  Global settings (Theme Settings > Custom Homepage):
    - ch_page_width  → controls max-width of content container

  Section settings:
    - show_section   → show/hide toggle
    - text_alignment → left | center | right
    - heading, bg/text color, padding
    - Blocks: "benefit" (icon, title, text, link) — up to 4
{% endcomment %}

{{ 'custom-homepage.css' | asset_url | stylesheet_tag }}

{%- if section.settings.show_section and section.blocks.size > 0 -%}

<section
  id="custom-benefits-{{ section.id }}"
  class="ch-section ch-benefits"
  style="
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    text-align: {{ section.settings.text_alignment }};
    --ch-ben-pt: {{ section.settings.padding_top }}px;
    --ch-ben-pb: {{ section.settings.padding_bottom }}px;
    --ch-page-width: {{ settings.ch_page_width | default: 1200 }}px;
  "
>
  <div class="ch-container">

    {%- if section.settings.heading != blank -%}
      <div class="ch-section-header">
        <h2 class="ch-section-header__title">{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="ch-benefits__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'benefit' -%}
          <div class="ch-benefit" {{ block.shopify_attributes }}>

            {%- if block.settings.icon != blank -%}
              <div class="ch-benefit__icon">
                {{
                  block.settings.icon
                  | image_url: width: 120
                  | image_tag:
                    alt: block.settings.icon_alt,
                    loading: 'lazy',
                    widths: '52, 80, 120'
                }}
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <p class="ch-benefit__title">{{ block.settings.title | escape }}</p>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="ch-benefit__text">
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
                {%- else -%}
                  {{ block.settings.text | escape }}
                {%- endif -%}
              </p>
            {%- endif -%}

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "Custom Benefits",
  "tag": "section",
  "class": "ch-benefits-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Visibility & Global"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "info": "Leave blank to hide.",
      "default": "Why Shop With Us"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon / Image"
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Icon Alt Text",
          "default": "Benefit icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Free delivery on orders over $50."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)",
          "info": "Wraps the description text in a link. Leave blank to disable."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Benefits",
      "settings": {
        "show_section": true,
        "text_alignment": "center"
      },
      "blocks": [
        { "type": "benefit", "settings": { "title": "Fast Shipping",      "text": "Free delivery on orders over $50."       } },
        { "type": "benefit", "settings": { "title": "Secure Checkout",    "text": "Your payment info is always protected."  } },
        { "type": "benefit", "settings": { "title": "Quality Guarantee",  "text": "Loved it or we'll make it right."       } },
        { "type": "benefit", "settings": { "title": "2-Year Warranty",    "text": "Every product backed by our warranty."   } }
      ]
    }
  ]
}
{% endschema %}
